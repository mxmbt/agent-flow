{
  "name": "@mxmbt/agent-flow",
  "version": "0.0.0",
  "description": "Project-agnostic agent orchestration package and installer for Claude Code and Codex.",
  "type": "module",
  "bin": {
    "agent-flow": "./dist/src/cli/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agents",
    "claude-code",
    "codex",
    "orchestration"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5"
  }

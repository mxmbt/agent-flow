#!/bin/bash
set -euo pipefail

REMOTE="{{git.remoteName}}"
INTEGRATION_BRANCH="{{git.integrationBranch}}"
RELEASE_BRANCH="{{git.releaseBranch}}"

CURRENT_WORKTREE="${PWD}"
CURRENT_BRANCH="$(git branch --show-current)"
DIRNAME="$(basename "$CURRENT_WORKTREE")"
PARKING_BRANCH="worktree/$DIRNAME"

fail() {
  echo "ERROR: $1" >&2
  exit 1
}

is_protected_branch() {
  local branch_name="$1"
  [[ "$branch_name" == "$INTEGRATION_BRANCH" ]] && return 0
  [[ "$RELEASE_BRANCH" != "none configured" && "$branch_name" == "$RELEASE_BRANCH" ]] && return 0
  return 1
}

set_parking_branch() {
  local worktree_path="$1"
  local branch_name="$2"

  git -C "$worktree_path" checkout -B "$branch_name" "$REMOTE/$INTEGRATION_BRANCH" >/dev/null
  git -C "$worktree_path" branch --unset-upstream >/dev/null 2>&1 || true
  git -C "$worktree_path" branch --set-upstream-to="$REMOTE/$INTEGRATION_BRANCH" "$branch_name" >/dev/null
}

assert_parking_state() {
  local worktree_path="$1"
  local branch_name="$2"
  local actual_branch
  local actual_upstream
  local actual_head
  local integration_head

  actual_branch="$(git -C "$worktree_path" branch --show-current)"
  [[ "$actual_branch" == "$branch_name" ]] || fail "$worktree_path is on '$actual_branch', expected '$branch_name'"

  actual_upstream="$(git -C "$worktree_path" rev-parse --abbrev-ref --symbolic-full-name '@{u}')"
  [[ "$actual_upstream" == "$REMOTE/$INTEGRATION_BRANCH" ]] || fail "$worktree_path tracks '$actual_upstream', expected '$REMOTE/$INTEGRATION_BRANCH'"

  actual_head="$(git -C "$worktree_path" rev-parse HEAD)"
  integration_head="$(git -C "$worktree_path" rev-parse "$REMOTE/$INTEGRATION_BRANCH")"
  [[ "$actual_head" == "$integration_head" ]] || fail "$worktree_path HEAD does not match $REMOTE/$INTEGRATION_BRANCH"
}

if is_protected_branch "$CURRENT_BRANCH"; then
  fail "run park-worktrees.sh from a feature/bugfix/infra worktree, not '$CURRENT_BRANCH'"
fi

git fetch "$REMOTE" --prune >/dev/null

MAIN_WORKTREE="$(git worktree list --porcelain | awk -v branch="refs/heads/$INTEGRATION_BRANCH" '/^worktree /{wt=$2} $0 == "branch " branch {print wt; exit}')"
if [[ -n "$MAIN_WORKTREE" ]]; then
  git -C "$MAIN_WORKTREE" pull --ff-only "$REMOTE" "$INTEGRATION_BRANCH" >/dev/null
fi

set_parking_branch "$CURRENT_WORKTREE" "$PARKING_BRANCH"

if [[ "$CURRENT_BRANCH" == feature/* || "$CURRENT_BRANCH" == bugfix/* || "$CURRENT_BRANCH" == hotfix/* || "$CURRENT_BRANCH" == infra/* ]]; then
  git branch -D "$CURRENT_BRANCH" >/dev/null
fi

while read -r worktree_path; do
  [[ -z "$worktree_path" || "$worktree_path" == "$CURRENT_WORKTREE" ]] && continue
  worktree_name="$(basename "$worktree_path")"
  set_parking_branch "$worktree_path" "worktree/$worktree_name"
  assert_parking_state "$worktree_path" "worktree/$worktree_name"
done < <(git worktree list --porcelain | awk '/^worktree /{wt=$2} /^branch refs\/heads\/worktree\//{print wt}')

assert_parking_state "$CURRENT_WORKTREE" "$PARKING_BRANCH"

echo "Parked current worktree on $PARKING_BRANCH tracking $REMOTE/$INTEGRATION_BRANCH"
